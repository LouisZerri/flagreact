{
    "name": "flagreact",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "concurrently -n vite,api -c cyan,magenta \"vite\" \"npm:server\"",
        "vite": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "server": "json-server --watch src/assets/db.json --port 3003",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-router-dom": "^7.6.0",
        "react-toastify": "^11.0.5"
    },
    "devDependencies": {
        "@eslint/js": "^9.27.0",
        "@vitejs/plugin-react": "^4.4.1",
        "concurrently": "^9.1.2",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.2.0",
        "json-server": "^0.17.4",
        "prettier": "^3.5.3",
        "sass": "^1.89.0",
        "vite": "^6.3.5"
    }
}
